# PAI Mobile Gateway — Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Identity ────────────────────────────────────────────────
# Your bot's name and your name (used in system prompts)
BOT_NAME=MyBot
USER_NAME=YourName

# ─── Telegram ────────────────────────────────────────────────
# Get a bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Your Telegram chat ID (send /start to @userinfobot to find it)
# Comma-separated for multiple authorized users
TELEGRAM_CHAT_ID=your-chat-id

# ─── Timezone ────────────────────────────────────────────────
# IANA timezone for heartbeat active hours and cron schedules
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# TIMEZONE=America/Denver

# ─── Claude (Optional) ──────────────────────────────────────
# Model for lite mode responses (default: sonnet)
# LITE_MODEL=sonnet

# Model for full mode responses (default: sonnet)
# FULL_MODEL=sonnet

# Permission mode for claude -p (default: default)
# Options:
#   default          — Claude asks for confirmation on risky actions (RECOMMENDED)
#   acceptEdits      — Auto-approve file edits, ask for other actions
#   bypassPermissions — No confirmations at all (use at your own risk)
# PERMISSION_MODE=default

# ─── Rate Limits (Optional) ──────────────────────────────────────
# Max messages per chat per minute (default: 20)
# MAX_MESSAGES_PER_MINUTE=20

# Max concurrent claude -p processes (default: 3)
# MAX_CONCURRENT_CLAUDE=3

# ─── Heartbeat (Optional) ────────────────────────────────────
# To enable the heartbeat system:
# 1. Copy data/heartbeat-config.example.json to data/heartbeat-config.json
# 2. Set "enabled": true in the config
# 3. Create ~/.claude/HEARTBEAT.md with your checklist
# The heartbeat checks in periodically and alerts only when something is actionable.
